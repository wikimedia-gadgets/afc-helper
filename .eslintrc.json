{
	"extends": [
		"wikimedia/client",
		"wikimedia/jquery",
		"wikimedia/mediawiki"
	],
	"env": {
		"browser": true,
		"jquery": true
	},
	"globals": {
		"AFCH": "writable",
		"Hogan": "readonly",
		"importScript": "readonly",
		"mediaWiki": "writable",
		"mw": "writable",
		"OO": "readonly"
	},
	"overrides": [
		{
			"files": [
				"tests/*"
			]
		}
	],
	"rules": {
		// default rules we don't like
		"camelcase": "off",
		"max-len": "off",
		"no-console": "off",
		"no-jquery/no-class-state": "off",
		"no-jquery/no-extend": "off",
		"no-jquery/no-global-selector": "off",
		"no-prototype-builtins": "off",
		"no-shadow": "off",
		"no-underscore-dangle": "off",
		"security/detect-non-literal-regexp": "off",
		"security/detect-unsafe-regex": "off",
		"unicorn/prefer-string-slice": "off",

		// non-default rules we do like
		"no-nested-ternary": "error",
		
		// rules we should probably fix someday
		"eqeqeq": "off",
		"es-x/no-regexp-s-flag": "off",
		"mediawiki/no-storage": "off",
		"no-global-assign": "off",
		"no-implicit-globals": "off",
		"no-jquery/no-animate": "off",
		"no-jquery/no-done-fail": "off",
		"no-jquery/no-each-util": "off",
		"no-jquery/no-grep": "off",
		"no-jquery/no-in-array": "off",
		"no-jquery/no-map-util": "off",
		"no-jquery/no-sizzle": "off",
		"no-jquery/no-slide": "off",
		"no-jquery/no-support": "off",
		"no-jquery/no-trim": "off",
		"no-undef": "off",
		"prefer-const": "off",
		"unicorn/prefer-includes": "off"
	}
}
